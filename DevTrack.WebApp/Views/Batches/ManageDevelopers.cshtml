@model List<DevTrack.Domain.Features.Batches.Models.BatchAssignmentModel>
@{
    var batch = ViewBag.Batch as DevTrack.Domain.Features.Batches.Models.BatchResponse;
    ViewData["Title"] = "Manage Developers - " + batch?.BatchName;
}

<div class="max-w-4xl mx-auto space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Manage Developers</h1>
            <p class="text-muted-foreground">Assign trainees to <strong>@batch?.BatchName</strong></p>
        </div>
        <a asp-action="Index" class="text-sm font-medium text-slate-500 hover:text-slate-900 transition-colors flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-chevron-left"><path d="m15 18-6-6 6-6"/></svg>
            Back to Batches
        </a>
    </div>

    <form asp-action="ManageDevelopers" method="post" class="space-y-6">
        <input type="hidden" name="id" value="@batch?.Id" />

        <div class="rounded-xl border bg-card text-card-foreground shadow overflow-hidden">
            <div class="p-6 border-b bg-slate-50/50">
                <h3 class="font-semibold leading-none tracking-tight">Developer Registry</h3>
                <p class="text-sm text-muted-foreground mt-1">Select the developers you want to include in this training batch.</p>
            </div>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-slate-200">
                @if (Model != null && Model.Any())
                {
                    @foreach (var dev in Model)
                    {
                        <div class="bg-white p-4 flex items-center justify-between hover:bg-slate-50 transition-colors group">
                            <div class="flex items-center gap-4">
                                <div class="relative flex h-10 w-10 shrink-0 overflow-hidden rounded-full bg-slate-100 items-center justify-center font-bold text-slate-600 border">
                                    @dev.FullName.Substring(0, Math.Min(2, dev.FullName.Length)).ToUpper()
                                </div>
                                <div>
                                    <p class="text-sm font-medium leading-none">@dev.FullName</p>
                                    <p class="text-xs text-muted-foreground mt-1 font-mono">@dev.DeveloperCode</p>
                                </div>
                            </div>
                            <div class="flex items-center space-x-2">
                                <input type="checkbox" name="selectedDeveloperIds" value="@dev.DeveloperId" @(dev.IsAssigned ? "checked" : "")
                                       class="h-5 w-5 rounded border-slate-300 text-primary focus:ring-primary transition-all cursor-pointer" />
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="bg-white p-12 text-center col-span-2">
                        <p class="text-sm text-muted-foreground">No active developers available for assignment.</p>
                        <a asp-controller="Developers" asp-action="Create" class="mt-4 inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-primary text-primary-foreground shadow hover:bg-primary/90 h-10 px-6 py-2">
                            Add Developer
                        </a>
                    </div>
                }
            </div>
        </div>

        <div class="flex items-center justify-end gap-4 pt-4">
            <a asp-action="Index" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground h-11 px-8 py-2">
                Discard Changes
            </a>
            <button type="submit" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-primary text-primary-foreground shadow hover:bg-primary/90 h-11 px-12 py-2">
                Save Assignments
            </button>
        </div>
    </form>
</div>
