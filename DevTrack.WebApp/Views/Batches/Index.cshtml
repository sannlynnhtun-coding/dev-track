@model DevTrack.Shared.PagedResult<DevTrack.Domain.Features.Batches.Models.BatchResponse>
@{
    ViewData["Title"] = "Training Batches";
}

<div class="space-y-10 animate-in">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Training Batches</h1>
            <p class="text-lg text-slate-500 mt-1">Manage your training groups and curriculum schedules.</p>
        </div>
        <a asp-action="Create" class="inline-flex items-center justify-center rounded-xl text-sm font-bold transition-all bg-primary text-white shadow-lg shadow-primary/20 hover:bg-primary/90 h-11 px-6 active:scale-95">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Create New Batch
        </a>
    </div>

    <div class="premium-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="h-14 px-6 text-left align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Batch Name</th>
                        <th class="h-14 px-6 text-left align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Mentor</th>
                        <th class="h-14 px-6 text-left align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Duration</th>
                        <th class="h-14 px-6 text-right align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (Model != null && Model.Data.Any())
                    {
                        @foreach (var batch in Model.Data)
                        {
                            <tr class="group hover:bg-slate-50/50 transition-colors">
                                <td class="p-6 align-middle">
                                    <div class="flex items-center gap-3">
                                        <div class="w-10 h-10 rounded-xl bg-primary/5 text-primary flex items-center justify-center font-bold text-lg group-hover:bg-primary group-hover:text-white transition-all duration-300">
                                            @batch.BatchName.Substring(0, 1)
                                        </div>
                                        <span class="font-bold text-slate-700 text-base">@batch.BatchName</span>
                                    </div>
                                </td>
                                <td class="p-6 align-middle">
                                    <div class="flex items-center gap-2">
                                        <div class="w-6 h-6 rounded-full bg-slate-100 flex items-center justify-center text-[10px] font-bold text-slate-500">
                                            @batch.MentorName.Substring(0, 1)
                                        </div>
                                        <span class="text-slate-600 font-medium">@batch.MentorName</span>
                                    </div>
                                </td>
                                <td class="p-6 align-middle">
                                    <div class="flex flex-col">
                                        <span class="text-sm font-semibold text-slate-700">@batch.DateRange</span>
                                        <div class="flex items-center gap-2 mt-1">
                                            <span class="px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 text-[10px] font-bold uppercase tracking-tight">@batch.TrainingMonths Months</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-6 align-middle text-right">
                                    <div class="flex items-center justify-end gap-3">
                                        <a asp-action="ManageDevelopers" asp-route-id="@batch.Id" class="inline-flex items-center justify-center rounded-lg text-xs font-bold border border-slate-200 bg-white hover:border-primary/30 hover:text-primary h-9 px-4 transition-all">
                                            Manage Devs
                                        </a>
                                        <a asp-controller="Attendance" asp-action="Schedule" asp-route-batchId="@batch.Id" class="inline-flex items-center justify-center rounded-lg text-xs font-bold bg-slate-900 text-white hover:bg-slate-800 h-9 px-4 transition-all shadow-sm">
                                            Schedule
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="p-12 text-center">
                                <div class="flex flex-col items-center justify-center opacity-40">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="mb-4"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
                                    <p class="text-lg font-semibold">No batches found</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="p-6 border-t border-slate-50 bg-slate-50/30">
            <partial name="_Pagination" model="Model.Pagination" />
        </div>
    </div>
</div>
