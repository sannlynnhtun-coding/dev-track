@model DevTrack.Shared.PagedResult<DevTrack.Domain.Features.Developers.Models.DeveloperResponse>
@{
    ViewData["Title"] = "Developers";
}

<div class="space-y-10 animate-in">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Developers</h1>
            <p class="text-lg text-slate-500 mt-1">Manage and track your developer training progress.</p>
        </div>
        <a asp-action="Create" class="inline-flex items-center justify-center rounded-xl text-sm font-bold transition-all bg-primary text-white shadow-lg shadow-primary/20 hover:bg-primary/90 h-11 px-6 active:scale-95">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
            Add Developer
        </a>
    </div>

    <div class="premium-card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="h-14 px-6 text-left align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Developer</th>
                        <th class="h-14 px-6 text-left align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Code</th>
                        <th class="h-14 px-6 text-left align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Email</th>
                        <th class="h-14 px-6 text-right align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (Model != null && Model.Data.Any())
                    {
                        @foreach (var dev in Model.Data)
                        {
                            <tr class="group hover:bg-slate-50/50 transition-colors">
                                <td class="p-6 align-middle">
                                    <div class="flex items-center gap-4">
                                        <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-slate-100 to-slate-200 border-2 border-white shadow-sm flex items-center justify-center text-sm font-bold text-slate-600 group-hover:border-primary/30 transition-all">
                                            @dev.FullName.Substring(0, 1)
                                        </div>
                                        <div class="flex flex-col">
                                            <span class="font-bold text-slate-700 text-base">@dev.FullName</span>
                                            <span class="text-xs text-slate-400 font-medium">Developer ID</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-6 align-middle">
                                    <span class="px-3 py-1 rounded-lg bg-primary/5 text-primary text-xs font-bold border border-primary/10">
                                        @dev.DeveloperCode
                                    </span>
                                </td>
                                <td class="p-6 align-middle">
                                    <div class="flex flex-col gap-1">
                                        <div class="flex items-center gap-2 text-slate-600">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                                            <span class="text-xs font-medium">@dev.Email</span>
                                        </div>
                                    </div>
                                </td>
                                <td class="p-6 align-middle text-right">
                                    <div class="flex items-center justify-end gap-3">
                                        <a asp-action="Details" asp-route-id="@dev.Id" class="inline-flex items-center justify-center rounded-lg text-xs font-bold border border-slate-200 bg-white hover:border-primary/30 hover:text-primary h-9 px-4 transition-all">
                                            Profile
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@dev.Id" class="inline-flex items-center justify-center rounded-lg text-xs font-bold bg-slate-900 text-white hover:bg-slate-800 h-9 px-4 transition-all shadow-sm">
                                            Edit
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="p-16 text-center text-slate-400">
                                <div class="flex flex-col items-center justify-center opacity-30">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mb-4"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                    <p class="text-xl font-bold">No developers found</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="p-6 border-t border-slate-50 bg-slate-50/30">
            <partial name="_Pagination" model="Model.Pagination" />
        </div>
    </div>
</div>
