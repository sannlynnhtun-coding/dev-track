@model DevTrack.Domain.Features.Training.Models.BulkAttendanceRequest
@{
    var batch = ViewBag.Batch as DevTrack.Domain.Features.Batches.Models.BatchResponse;
    var classDays = ViewBag.ClassDays as List<DateOnly> ?? new List<DateOnly>();
    var targetDate = ViewBag.TargetDate != null ? (DateOnly)ViewBag.TargetDate : DateOnly.FromDateTime(DateTime.Now);
    ViewData["Title"] = $"Mark Attendance - {batch?.BatchName}";
}

<div class="max-w-5xl mx-auto space-y-10 animate-in">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-100 pb-8">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <a asp-action="Index" asp-route-batchId="@batch?.Id" class="text-xs font-bold uppercase tracking-wider text-primary hover:underline">Attendance Dashboard</a>
                <span class="text-slate-300">/</span>
                <span class="text-xs font-bold uppercase tracking-wider text-slate-400">Mark Records</span>
            </div>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Daily Attendance</h1>
            <p class="text-lg text-slate-500 mt-1">Recording for <span class="font-bold text-slate-900">@(batch?.BatchName ?? "Unknown Batch")</span></p>
        </div>
        <div class="flex items-center gap-4">
            @if (batch != null)
            {
                <div class="relative min-w-[200px]">
                    <select onchange="location.href='?batchId=@batch.Id&date=' + this.value" class="h-11 pl-4 pr-10 text-sm font-bold border border-slate-200 rounded-xl bg-white appearance-none focus:ring-2 focus:ring-primary/20 focus:border-primary w-full cursor-pointer shadow-sm">
                        @foreach (var day in classDays)
                        {
                            <!option value="@day.ToString("yyyy-MM-dd")" @(day == targetDate ? "selected" : "")>
                                @day.ToString("MMM dd, yyyy")
                            </!option>
                        }
                    </select>
                    <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-slate-400">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
                    </div>
                </div>
                <a asp-action="Schedule" asp-route-batchId="@batch.Id" class="inline-flex items-center justify-center rounded-xl text-sm font-bold border border-slate-200 bg-white hover:bg-slate-50 h-11 px-6 transition-all">
                    Cancel
                </a>
            }
        </div>
    </div>

    @if (targetDate > DateOnly.FromDateTime(DateTime.Now))
    {
        <div class="rounded-2xl border-2 border-dashed border-amber-200 bg-amber-50/50 p-6 text-amber-800 flex gap-4 items-center">
            <div class="w-10 h-10 rounded-full bg-amber-100 flex items-center justify-center text-amber-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            </div>
            <p class="text-sm font-bold">Note: You are marking for a future session. Data will be pre-saved for that date.</p>
        </div>
    }

    <form asp-action="Mark" method="post" class="space-y-8">
        @if (Model != null)
        {
            <input type="hidden" asp-for="BatchId" />
            <input type="hidden" asp-for="TrainingDate" />
        }

        <div class="premium-card overflow-hidden">
            <table class="w-full text-sm">
                <thead>
                    <tr class="bg-slate-50/50 border-b border-slate-100">
                        <th class="h-14 px-6 text-left align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px] w-[300px]">Developer</th>
                        <th class="h-14 px-6 text-center align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Attendance Status</th>
                        <th class="h-14 px-6 text-left align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Remarks</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @if (Model != null && Model.Markings != null)
                    {
                        @for (int i = 0; i < Model.Markings.Count; i++)
                        {
                            <tr class="group hover:bg-slate-50/50 transition-colors">
                                <td class="p-6 align-middle">
                                    <input type="hidden" asp-for="Markings[i].DeveloperId" />
                                    <input type="hidden" asp-for="Markings[i].FullName" />
                                    <div class="flex items-center gap-4">
                                        <div class="w-10 h-10 rounded-xl bg-primary/5 text-primary flex items-center justify-center font-black text-xs border border-primary/10">
                                            @Model.Markings[i].FullName?.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="font-bold text-slate-700">@Model.Markings[i].FullName</span>
                                    </div>
                                </td>
                                <td class="p-6 align-middle">
                                    <div class="flex items-center justify-center gap-1 rounded-xl border border-slate-100 p-1 bg-slate-50/50 w-fit mx-auto shadow-inner">
                                        @foreach (var status in new[] { "Present", "Absent", "Late", "Leave" })
                                        {
                                            <label class="relative flex items-center justify-center px-4 py-2 rounded-lg cursor-pointer transition-all group">
                                                <input type="radio" asp-for="Markings[i].Status" value="@status" class="peer sr-only" />
                                                @{
                                                    var colorClass = status switch {
                                                        "Present" => "peer-checked:bg-emerald-500 peer-checked:text-white",
                                                        "Absent" => "peer-checked:bg-rose-500 peer-checked:text-white",
                                                        "Late" => "peer-checked:bg-amber-500 peer-checked:text-white",
                                                        "Leave" => "peer-checked:bg-blue-500 peer-checked:text-white",
                                                        _ => ""
                                                    };
                                                }
                                                <span class="text-[10px] font-black uppercase tracking-wider text-slate-400 transition-all @colorClass px-3 py-1.5 rounded-lg">@status</span>
                                            </label>
                                        }
                                    </div>
                                </td>
                                <td class="p-6 align-middle">
                                    <input asp-for="Markings[i].Remark" placeholder="Add note..." class="flex h-11 w-full rounded-xl border border-slate-200 bg-white/50 px-4 py-2 text-xs font-medium shadow-sm transition-all focus:ring-2 focus:ring-primary/10 focus:border-primary outline-none" />
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="p-16 text-center text-slate-400 italic font-bold">
                                No developers found to mark attendance.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="flex items-center justify-end gap-6 pt-4">
            <button type="submit" @(Model == null ? "disabled" : "") class="inline-flex items-center justify-center rounded-xl text-base font-bold transition-all bg-slate-900 text-white shadow-2xl hover:bg-slate-800 h-14 px-16 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">
                Save & Synchronize Records
            </button>
        </div>
    </form>
</div>

