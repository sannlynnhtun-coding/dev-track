@model DevTrack.Shared.PagedResult<DevTrack.Domain.Features.Training.Models.AttendanceSummaryResponse>
@{
    ViewData["Title"] = "Attendance Dashboard";
    var batches = ViewBag.Batches as List<DevTrack.Domain.Features.Batches.Models.BatchResponse>;
    int? selectedBatchId = ViewBag.SelectedBatchId as int?;
}

<div class="space-y-10 animate-in">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-100 pb-8">
        <div>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Attendance Analytics</h1>
            <p class="text-lg text-slate-500 mt-2">Track eligibility and participation across all training batches.</p>
        </div>
        <div class="flex items-center gap-4">
            <form asp-action="Index" method="get" class="min-w-[240px]">
                <select name="batchId" onchange="this.form.submit()" class="flex h-11 w-full rounded-xl border border-slate-200 bg-white px-4 py-2 text-sm font-semibold text-slate-700 shadow-sm focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all outline-none appearance-none cursor-pointer">
                    <option value="">Select a Batch</option>
                    @if (batches != null)
                    {
                        @foreach (var batch in batches)
                        {
                            if (selectedBatchId == batch.Id)
                            {
                                <option value="@batch.Id" selected>@batch.BatchName</option>
                            }
                            else
                            {
                                <option value="@batch.Id">@batch.BatchName</option>
                            }
                        }
                    }
                </select>
            </form>
            @if (selectedBatchId > 0)
            {
                <div class="flex items-center gap-3">
                    <a asp-action="Download" asp-route-batchId="@selectedBatchId" class="inline-flex items-center justify-center rounded-xl text-sm font-bold border border-slate-200 bg-white hover:bg-slate-50 h-11 px-6 transition-all">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2 text-slate-400"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                        Download Report
                    </a>
                    <a asp-action="Mark" asp-route-batchId="@selectedBatchId" class="inline-flex items-center justify-center rounded-xl text-sm font-bold bg-primary text-white shadow-lg shadow-primary/20 hover:bg-primary/90 h-11 px-6 transition-all active:scale-95">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                        Mark Attendance
                    </a>
                </div>
            }
        </div>
    </div>

    @if (selectedBatchId.HasValue && selectedBatchId > 0)
    {
        <div class="premium-card overflow-hidden">
            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="bg-slate-50/50 border-b border-slate-100">
                            <th class="h-14 px-6 text-left align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Developer</th>
                            <th class="h-14 px-6 text-center align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Present</th>
                            <th class="h-14 px-6 text-center align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Absent</th>
                            <th class="h-14 px-6 text-center align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Leave</th>
                            <th class="h-14 px-6 text-center align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Performance</th>
                            <th class="h-14 px-6 text-right align-middle font-bold text-slate-400 uppercase tracking-widest text-[11px]">Eligibility</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-50">
                        @if (Model != null && Model.Data.Any())
                        {
                            @foreach (var item in Model.Data)
                            {
                                <tr class="group hover:bg-slate-50/50 transition-colors">
                                    <td class="p-6 align-middle font-bold text-slate-700">@item.FullName</td>
                                    <td class="p-6 align-middle text-center font-mono font-bold text-emerald-600">@item.PresentDays</td>
                                    <td class="p-6 align-middle text-center font-mono font-bold text-rose-600">@item.AbsentDays</td>
                                    <td class="p-6 align-middle text-center font-mono font-bold text-amber-600">@item.LeaveDays</td>
                                    <td class="p-6 align-middle">
                                        <div class="flex flex-col items-center gap-2">
                                            <div class="w-24 bg-slate-100 rounded-full h-2 overflow-hidden shadow-inner">
                                                <div class="@(item.AttendancePercent >= 80 ? "bg-emerald-500" : (item.AttendancePercent >= 70 ? "bg-amber-500" : "bg-primary")) h-full rounded-full transition-all duration-1000" 
                                                     style="width: @item.AttendancePercent%"></div>
                                            </div>
                                            <span class="font-mono text-[11px] font-extrabold text-slate-500">@item.AttendancePercent.ToString("0.0")%</span>
                                        </div>
                                    </td>
                                    <td class="p-6 align-middle text-right">
                                        @if (item.Status == "Eligible")
                                        {
                                            <span class="px-3 py-1 rounded-full bg-emerald-100 text-emerald-700 text-[10px] font-bold uppercase tracking-wider">Eligible</span>
                                        }
                                        else if (item.Status == "Warning")
                                        {
                                            <span class="px-3 py-1 rounded-full bg-amber-100 text-amber-700 text-[10px] font-bold uppercase tracking-wider">Warning</span>
                                        }
                                        else
                                        {
                                            <span class="px-3 py-1 rounded-full bg-rose-100 text-rose-700 text-[10px] font-bold uppercase tracking-wider">Restricted</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="p-16 text-center text-slate-400">
                                    <div class="flex flex-col items-center justify-center opacity-30">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="mb-4"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                                        <p class="text-xl font-bold">No records found for this batch</p>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-6 border-t border-slate-50 bg-slate-50/30">
                <partial name="_Pagination" model="Model.Pagination" />
            </div>
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-32 bg-white/50 backdrop-blur-sm border-2 border-dashed border-slate-200 rounded-2xl group transition-all hover:bg-white hover:border-primary/20">
            <div class="w-24 h-24 rounded-full bg-slate-50 flex items-center justify-center mb-8 group-hover:bg-primary/5 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300 group-hover:text-primary transition-colors"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/><path d="m9 16 2 2 4-4"/></svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-900">Select Training Batch</h3>
            <p class="text-slate-500 mt-2 max-w-sm text-center leading-relaxed">Choose a batch from the dropdown above to view detailed attendance performance and eligibility status.</p>
        </div>
    }
</div>
