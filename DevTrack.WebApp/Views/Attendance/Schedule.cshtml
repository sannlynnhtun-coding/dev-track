@model DevTrack.Shared.PagedResult<DevTrack.Domain.Features.Training.Models.TrainingCalendarResponse>
@{
    var batch = ViewBag.Batch as DevTrack.Domain.Features.Batches.Models.BatchResponse;
    ViewData["Title"] = $"Training Schedule - {batch?.BatchName}";
}

<div class="max-w-5xl mx-auto space-y-10 animate-in">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 border-b border-slate-100 pb-8">
        <div>
            <div class="flex items-center gap-2 mb-2">
                <a asp-controller="Batches" asp-action="Index" class="text-xs font-bold uppercase tracking-wider text-primary hover:underline">Batches</a>
                <span class="text-slate-300">/</span>
                <span class="text-xs font-bold uppercase tracking-wider text-slate-400">@batch?.BatchName</span>
            </div>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Training Schedule</h1>
            <p class="text-lg text-slate-500 mt-1">Comprehensive calendar for your training curriculum.</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Index" asp-route-batchId="@batch?.Id" class="inline-flex items-center justify-center rounded-xl text-sm font-bold border border-slate-200 bg-white hover:border-primary/30 hover:text-primary h-11 px-6 transition-all shadow-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-2"><path d="M12 20h9"/><path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
                Attendance Summary
            </a>
        </div>
    </div>

    <div class="grid gap-4">
        @foreach (var item in Model.Data)
        {
            var isUpcoming = item.TrainingDate > DateOnly.FromDateTime(DateTime.Now);
            var isToday = item.TrainingDate == DateOnly.FromDateTime(DateTime.Now);
            
            <div class="premium-card group relative flex items-center justify-between p-5 @(isToday ? "ring-2 ring-primary bg-primary/5" : "")">
                <div class="flex items-center gap-8">
                    <div class="flex flex-col items-center justify-center w-20 h-20 rounded-2xl @(isToday ? "bg-primary text-white shadow-lg shadow-primary/30" : "bg-slate-50 text-slate-400 group-hover:bg-slate-100") transition-all">
                        <span class="text-[10px] font-black uppercase tracking-[0.2em]">@item.TrainingDate.ToString("MMM")</span>
                        <span class="text-3xl font-black">@item.TrainingDate.Day</span>
                    </div>

                    <div class="space-y-2">
                        <div class="flex items-center gap-3">
                            <h3 class="font-bold text-xl text-slate-800">@item.TrainingDate.ToString("dddd, MMM dd")</h3>
                            @if (isToday)
                            {
                                <span class="px-2.5 py-0.5 rounded-full text-[10px] font-black bg-primary text-white tracking-widest">TODAY</span>
                            }
                        </div>
                        
                        <div class="flex items-center gap-3">
                            @{
                                var badgeClass = item.DayType switch
                                {
                                    "Class Day" => "bg-blue-100 text-blue-700",
                                    "Assignment" => "bg-purple-100 text-purple-700",
                                    "Holiday" => "bg-rose-100 text-rose-700",
                                    "Close Day" => "bg-slate-100 text-slate-700",
                                    _ => "bg-slate-100 text-slate-700"
                                };
                            }
                            <span class="px-3 py-1 rounded-lg text-[10px] font-bold uppercase tracking-wider @badgeClass">
                                @item.DayType
                            </span>

                            @if (!string.IsNullOrEmpty(item.AssignmentTitle))
                            {
                                <span class="text-xs text-slate-400 font-bold flex items-center gap-1.5">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-slate-300"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
                                    @item.AssignmentTitle
                                </span>
                            }
                        </div>
                    </div>
                </div>

                <div class="flex items-center gap-6">
                    @if (item.IsAttendanceRequired)
                    {
                        @if (item.IsAttendanceMarked)
                        {
                            <div class="flex items-center gap-2 text-emerald-600 bg-emerald-50 px-3 py-2 rounded-xl border border-emerald-100 shadow-sm">
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                <span class="text-[11px] font-black uppercase tracking-wider">Completed</span>
                            </div>
                        }
                        else if (!isUpcoming || isToday)
                        {
                            <span class="text-[11px] font-black uppercase tracking-wider text-rose-500 bg-rose-50 px-3 py-2 rounded-xl border border-rose-100 shadow-sm">Pending</span>
                        }
                        
                        <a asp-action="Mark" asp-route-batchId="@item.BatchId" asp-route-date="@item.TrainingDate.ToString("yyyy-MM-dd")" 
                           class="inline-flex items-center justify-center rounded-xl text-sm font-bold h-12 px-8 @(item.IsAttendanceMarked ? "border-2 border-slate-100 bg-white hover:border-primary/20 hover:text-primary" : "bg-slate-900 text-white shadow-xl hover:bg-slate-800") transition-all active:scale-95">
                            @(item.IsAttendanceMarked ? "Edit" : "Mark")
                        </a>
                    }
                </div>
            </div>
        }
    </div>
    
    <div class="premium-card p-6 border-t border-slate-50 bg-slate-50/30 overflow-hidden">
        <partial name="_Pagination" model="Model.Pagination" />
    </div>
</div>
