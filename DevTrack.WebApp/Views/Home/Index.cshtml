@model DevTrack.Domain.Features.Dashboard.Models.DashboardResponse
@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-10 animate-in">
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-4xl font-extrabold tracking-tight text-slate-900">Dashboard</h1>
            <p class="text-lg text-slate-500 mt-1">Welcome back, mentor. Here's your training overview.</p>
        </div>
        <div class="flex items-center gap-3">
            <a asp-action="Download" class="inline-flex items-center justify-center rounded-xl text-sm font-semibold transition-all border border-slate-200 bg-white shadow-sm hover:bg-slate-50 h-11 px-5 gap-2 group">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400 group-hover:text-primary transition-colors"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
                Download Report
            </a>
        </div>
    </div>

    @if (Model != null)
    {
        <!-- Stats Grid -->
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
            <div class="premium-card p-6 relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div class="flex flex-col gap-1">
                    <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Active Batches</span>
                    <span class="text-4xl font-bold text-slate-900">@Model.ActiveBatches</span>
                    <span class="text-sm text-slate-400 mt-1">out of @Model.TotalBatches total</span>
                </div>
            </div>

            <div class="premium-card p-6 relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>
                </div>
                <div class="flex flex-col gap-1">
                    <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Total Developers</span>
                    <span class="text-4xl font-bold text-slate-900">@Model.TotalDevelopers</span>
                    <span class="text-sm text-slate-400 mt-1">Tracked in system</span>
                </div>
            </div>

            <div class="premium-card p-6 relative overflow-hidden group">
                <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                </div>
                <div class="flex flex-col gap-1">
                    <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider">Avg. Attendance</span>
                    <span class="text-4xl font-bold text-slate-900">@Model.OverallAttendanceRate%</span>
                    <div class="w-full bg-slate-100 rounded-full h-1.5 mt-3">
                        <div class="bg-primary h-full rounded-full" style="width: @Model.OverallAttendanceRate%"></div>
                    </div>
                </div>
            </div>

            <div class="premium-card p-6 relative overflow-hidden group border-l-4 border-l-primary">
                <div class="absolute top-0 right-0 p-3 opacity-10 group-hover:opacity-20 transition-opacity">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <div class="flex flex-col gap-1">
                    <span class="text-sm font-semibold text-slate-500 uppercase tracking-wider">System Status</span>
                    <span class="text-2xl font-bold text-primary">Excellent</span>
                    <span class="text-sm text-slate-400 mt-1">All metrics are healthy</span>
                </div>
            </div>
        </div>

        <!-- Recent Activity Section -->
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-7">
            <div class="col-span-4 premium-card flex flex-col">
                <div class="p-6 border-b border-slate-100 flex items-center justify-between">
                    <div>
                        <h3 class="font-bold text-lg text-slate-900">Recent Batches Overview</h3>
                        <p class="text-sm text-slate-500">Track progress across current sessions.</p>
                    </div>
                    <button class="text-xs font-bold text-primary hover:underline uppercase tracking-widest">View All</button>
                </div>
                <div class="p-6 overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="text-left text-slate-400 font-semibold uppercase tracking-wider text-[11px]">
                                <th class="pb-4 px-2">Batch Name</th>
                                <th class="pb-4 px-2">Mentor</th>
                                <th class="pb-4 px-2 text-right">Members</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-50">
                            @foreach (var batch in Model.RecentBatches)
                            {
                                <tr class="group hover:bg-slate-50/80 transition-colors">
                                    <td class="py-4 px-2">
                                        <div class="flex items-center gap-3">
                                            <div class="w-2 h-2 rounded-full bg-primary group-hover:scale-125 transition-transform"></div>
                                            <span class="font-bold text-slate-700">@batch.BatchName</span>
                                        </div>
                                    </td>
                                    <td class="py-4 px-2 text-slate-600">@batch.MentorName</td>
                                    <td class="py-4 px-2 text-right font-mono font-bold text-slate-900">@batch.DeveloperCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            
            <div class="col-span-3 premium-card flex flex-col">
                <div class="p-6 border-b border-slate-100">
                    <h3 class="font-bold text-lg text-slate-900">Attendance Trend</h3>
                    <p class="text-sm text-slate-500">Visualizing recent daily presence.</p>
                </div>
                <div class="p-6 space-y-6">
                    @foreach (var trend in Model.AttendanceTrends)
                    {
                        <div class="group">
                            <div class="flex items-center justify-between mb-2">
                                <span class="text-sm font-bold text-slate-700">@trend.Date</span>
                                <span class="text-xs font-semibold text-primary">@trend.PresentCount Developers</span>
                            </div>
                            <div class="w-full bg-slate-100 rounded-full h-3 overflow-hidden">
                                <div class="bg-gradient-to-r from-primary to-primary/60 h-full rounded-full transition-all duration-700 group-hover:saturate-150" 
                                     style="width: @(trend.PresentCount * 10)%"></div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="flex h-[450px] shrink-0 items-center justify-center rounded-2xl border-2 border-dashed border-slate-200 bg-white/50 backdrop-blur-sm">
            <div class="mx-auto flex max-w-[420px] flex-col items-center justify-center text-center p-8">
                <div class="w-20 h-20 rounded-full bg-slate-50 flex items-center justify-center mb-6">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" class="h-10 w-10 text-slate-300" viewBox="0 0 24 24"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>
                </div>
                <h3 class="text-2xl font-bold text-slate-900">No data available</h3>
                <p class="mt-3 text-slate-500 leading-relaxed">The dashboard is currently empty. Please ensure the backend services are running and the database is properly initialized.</p>
                <button onclick="window.location.reload()" class="mt-8 text-sm font-bold text-primary hover:underline uppercase tracking-widest">Refresh System</button>
            </div>
        </div>
    }
</div>
