@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Dashboard</h1>
            <p class="text-muted-foreground">Welcome back, mentor. Here is what's happening today.</p>
        </div>
        <div class="flex items-center gap-2">
            <button class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2">
                Download Report
            </button>
        </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        <div class="rounded-xl border bg-card text-card-foreground shadow">
            <div class="p-6 flex flex-row items-center justify-between space-y-0 pb-2">
                <h3 class="tracking-tight text-sm font-medium">Active Batches</h3>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="h-4 w-4 text-muted-foreground"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            </div>
            <div class="p-6 pt-0">
                <div class="text-2xl font-bold">12</div>
                <p class="text-xs text-muted-foreground">+2 from last month</p>
            </div>
        </div>
        <div class="rounded-xl border bg-card text-card-foreground shadow">
            <div class="p-6 flex flex-row items-center justify-between space-y-0 pb-2">
                <h3 class="tracking-tight text-sm font-medium">Total Developers</h3>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="h-4 w-4 text-muted-foreground"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>
            </div>
            <div class="p-6 pt-0">
                <div class="text-2xl font-bold">156</div>
                <p class="text-xs text-muted-foreground">+18 since start</p>
            </div>
        </div>
        <div class="rounded-xl border bg-card text-card-foreground shadow">
            <div class="p-6 flex flex-row items-center justify-between space-y-0 pb-2">
                <h3 class="tracking-tight text-sm font-medium">Avg. Attendance</h3>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="h-4 w-4 text-muted-foreground"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
            </div>
            <div class="p-6 pt-0">
                <div class="text-2xl font-bold">92.4%</div>
                <p class="text-xs text-muted-foreground">+1.2% this week</p>
            </div>
        </div>
        <div class="rounded-xl border bg-card text-card-foreground shadow border-l-4 border-l-destructive">
            <div class="p-6 flex flex-row items-center justify-between space-y-0 pb-2">
                <h3 class="tracking-tight text-sm font-medium">At Risk</h3>
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="h-4 w-4 text-destructive"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
            </div>
            <div class="p-6 pt-0">
                <div class="text-2xl font-bold">4</div>
                <p class="text-xs text-destructive">Developers below 80%</p>
            </div>
        </div>
    </div>

    <!-- Recent Activity Section -->
    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-7">
        <div class="col-span-4 rounded-xl border bg-card text-card-foreground shadow">
            <div class="p-6 flex flex-col space-y-1.5 pb-2">
                <h3 class="font-semibold leading-none tracking-tight">Active Batches Overview</h3>
                <p class="text-sm text-muted-foreground">Track progress across all current sessions.</p>
            </div>
            <div class="p-6">
                <!-- Table Mockup for Premium Feel -->
                <div class="relative w-full overflow-auto">
                    <table class="w-full caption-bottom text-sm">
                        <thead class="[&_tr]:border-b">
                            <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
                                <th class="h-10 px-2 text-left align-middle font-medium text-muted-foreground">Batch Name</th>
                                <th class="h-10 px-2 text-left align-middle font-medium text-muted-foreground">Status</th>
                                <th class="h-10 px-2 text-left align-middle font-medium text-muted-foreground">Progress</th>
                                <th class="h-10 px-2 text-right align-middle font-medium text-muted-foreground">Members</th>
                            </tr>
                        </thead>
                        <tbody class="[&_tr:last-child]:border-0">
                            <tr class="border-b transition-colors hover:bg-muted/50">
                                <td class="p-2 align-middle font-medium">.NET Fullstack Batch 01</td>
                                <td class="p-2 align-middle"><span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-emerald-100 text-emerald-800">Ongoing</span></td>
                                <td class="p-2 align-middle">
                                    <div class="w-[100px] bg-slate-100 rounded-full h-2">
                                        <div class="bg-primary h-2 rounded-full" style="width: 65%"></div>
                                    </div>
                                </td>
                                <td class="p-2 align-middle text-right">24</td>
                            </tr>
                            <tr class="border-b transition-colors hover:bg-muted/50">
                                <td class="p-2 align-middle font-medium">React Native Experts</td>
                                <td class="p-2 align-middle"><span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-amber-100 text-amber-800">Starting Soon</span></td>
                                <td class="p-2 align-middle">
                                    <div class="w-[100px] bg-slate-100 rounded-full h-2">
                                        <div class="bg-primary h-2 rounded-full" style="width: 5%"></div>
                                    </div>
                                </td>
                                <td class="p-2 align-middle text-right">18</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-span-3 rounded-xl border bg-card text-card-foreground shadow">
            <div class="p-6 flex flex-col space-y-1.5 pb-2">
                <h3 class="font-semibold leading-none tracking-tight">Recent Attendance</h3>
                <p class="text-sm text-muted-foreground">Today's recorded presence.</p>
            </div>
            <div class="p-6 space-y-8">
                <div class="flex items-center gap-4">
                    <span class="relative flex h-9 w-9 shrink-0 overflow-hidden rounded-full bg-slate-100 items-center justify-center font-bold">JD</span>
                    <div class="flex flex-col gap-1">
                        <p class="text-sm font-medium leading-none">John Doe</p>
                        <p class="text-sm text-muted-foreground">Present in .NET Batch 01</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <span class="relative flex h-9 w-9 shrink-0 overflow-hidden rounded-full bg-slate-100 items-center justify-center font-bold">AS</span>
                    <div class="flex flex-col gap-1">
                        <p class="text-sm font-medium leading-none">Alice Smith</p>
                        <p class="text-sm text-muted-foreground">Marked Late (15 mins)</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
