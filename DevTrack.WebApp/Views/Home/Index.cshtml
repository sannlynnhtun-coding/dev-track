@model DevTrack.Domain.Features.Dashboard.Models.DashboardResponse
@{
    ViewData["Title"] = "Dashboard";
}

<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold tracking-tight">Dashboard</h1>
            <p class="text-muted-foreground">Welcome back, mentor. Here is what's happening today.</p>
        </div>
        <div class="flex items-center gap-2">
            <button class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring disabled:pointer-events-none disabled:opacity-50 border border-input bg-background shadow-sm hover:bg-accent hover:text-accent-foreground h-9 px-4 py-2">
                Download Report
            </button>
        </div>
    </div>

    @if (Model != null)
    {
        <!-- Stats Grid -->
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
            <div class="rounded-xl border bg-card text-card-foreground shadow">
                <div class="p-6 flex flex-row items-center justify-between space-y-0 pb-2">
                    <h3 class="tracking-tight text-sm font-medium">Active Batches</h3>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="h-4 w-4 text-muted-foreground"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                </div>
                <div class="p-6 pt-0">
                    <div class="text-2xl font-bold">@Model.ActiveBatches</div>
                    <p class="text-xs text-muted-foreground">out of @Model.TotalBatches total</p>
                </div>
            </div>
            <div class="rounded-xl border bg-card text-card-foreground shadow">
                <div class="p-6 flex flex-row items-center justify-between space-y-0 pb-2">
                    <h3 class="tracking-tight text-sm font-medium">Total Developers</h3>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="h-4 w-4 text-muted-foreground"><rect width="20" height="14" x="2" y="5" rx="2"/><path d="M2 10h20"/></svg>
                </div>
                <div class="p-6 pt-0">
                    <div class="text-2xl font-bold">@Model.TotalDevelopers</div>
                    <p class="text-xs text-muted-foreground">Tracked in system</p>
                </div>
            </div>
            <div class="rounded-xl border bg-card text-card-foreground shadow">
                <div class="p-6 flex flex-row items-center justify-between space-y-0 pb-2">
                    <h3 class="tracking-tight text-sm font-medium">Avg. Attendance</h3>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="h-4 w-4 text-muted-foreground"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
                </div>
                <div class="p-6 pt-0">
                    <div class="text-2xl font-bold">@Model.OverallAttendanceRate%</div>
                    <p class="text-xs text-muted-foreground">Overall class presence</p>
                </div>
            </div>
            <div class="rounded-xl border bg-card text-card-foreground shadow">
                <div class="p-6 flex flex-row items-center justify-between space-y-0 pb-2">
                    <h3 class="tracking-tight text-sm font-medium">Success Rate</h3>
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="h-4 w-4 text-muted-foreground"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                </div>
                <div class="p-6 pt-0">
                    <div class="text-2xl font-bold">High</div>
                    <p class="text-xs text-muted-foreground">Based on recent metrics</p>
                </div>
            </div>
        </div>

        <!-- Recent Activity Section -->
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-7">
            <div class="col-span-4 rounded-xl border bg-card text-card-foreground shadow">
                <div class="p-6 flex flex-col space-y-1.5 pb-2">
                    <h3 class="font-semibold leading-none tracking-tight">Recent Batches Overview</h3>
                    <p class="text-sm text-muted-foreground">Track progress across all current sessions.</p>
                </div>
                <div class="p-6">
                    <div class="relative w-full overflow-auto">
                        <table class="w-full caption-bottom text-sm">
                            <thead class="[&_tr]:border-b">
                                <tr class="border-b transition-colors hover:bg-muted/50 data-[state=selected]:bg-muted">
                                    <th class="h-10 px-2 text-left align-middle font-medium text-muted-foreground">Batch Name</th>
                                    <th class="h-10 px-2 text-left align-middle font-medium text-muted-foreground">Mentor</th>
                                    <th class="h-10 px-2 text-right align-middle font-medium text-muted-foreground">Members</th>
                                </tr>
                            </thead>
                            <tbody class="[&_tr:last-child]:border-0">
                                @foreach (var batch in Model.RecentBatches)
                                {
                                    <tr class="border-b transition-colors hover:bg-muted/50">
                                        <td class="p-2 align-middle font-medium">@batch.BatchName</td>
                                        <td class="p-2 align-middle">@batch.MentorName</td>
                                        <td class="p-2 align-middle text-right">@batch.DeveloperCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="col-span-3 rounded-xl border bg-card text-card-foreground shadow">
                <div class="p-6 flex flex-col space-y-1.5 pb-2">
                    <h3 class="font-semibold leading-none tracking-tight">Attendance Trend</h3>
                    <p class="text-sm text-muted-foreground">Presence count over last recorded sessions.</p>
                </div>
                <div class="p-6 space-y-4">
                    @foreach (var trend in Model.AttendanceTrends)
                    {
                        <div class="flex items-center gap-4">
                            <div class="w-12 text-sm font-medium">@trend.Date</div>
                            <div class="flex-1 bg-slate-100 rounded-full h-4 overflow-hidden">
                                <div class="bg-primary h-full transition-all" style="width: @(trend.PresentCount * 20)%"></div>
                            </div>
                            <div class="text-sm font-medium">@trend.PresentCount devs</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="flex h-[450px] shrink-0 items-center justify-center rounded-md border border-dashed">
            <div class="mx-auto flex max-w-[420px] flex-col items-center justify-center text-center">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" class="h-10 w-10 text-muted-foreground" viewBox="0 0 24 24"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4"/><path d="M3 5v14a2 2 0 0 0 2 2h16v-5"/><path d="M18 12a2 2 0 0 0 0 4h4v-4Z"/></svg>
                <h3 class="mt-4 text-lg font-semibold">No data available</h3>
                <p class="mb-4 mt-2 text-sm text-muted-foreground">Please start the API and ensure database connection is active.</p>
            </div>
        </div>
    }
</div>
